# Database
POSTGRES_DB=matquiz_db
POSTGRES_USER=admin
POSTGRES_PASSWORD=change_this_db_password

# RabbitMQ
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=change_this_rabbitmq_password

# Backend JWT
# Generate at least 32 random characters.
SECURITY_SECRET=change_this_to_a_long_random_secret
SECURITY_VALIDITY=900000
APP_CORS_ALLOWED_ORIGINS=https://matquiz.example.com

# AI Worker
GEMINI_API_KEY=replace_with_your_gemini_api_key
MAX_PROCESS_RETRIES=3

# Frontend
VITE_API_URL=https://api.matquiz.mateistanescu.ro/api
VITE_WS_URL=https://api.matquiz.mateistanescu.ro/ws
